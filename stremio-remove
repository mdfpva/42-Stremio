#!/bin/zsh
# Desinstalador total do Stremio (sgoinfre) — remove tudo o que foi criado

SGOINFRE_PATH="$HOME/sgoinfre"

echo "=== Desinstalador total do Stremio ==="

echo "-> A terminar processos do Stremio em execução..."
pkill -f "stremio-shell/stremio" 2>/dev/null || true
pkill -f "stremio-shell/server.js" 2>/dev/null || true
pkill -f "stremio-shell/node" 2>/dev/null || true
pkill -f "server.js" 2>/dev/null || true
sleep 1

echo "-> Removendo a instalação no sgoinfre..."
rm -rf "$SGOINFRE_PATH/stremio-shell"
rm -rf "$SGOINFRE_PATH/qt"
rm -rf "$SGOINFRE_PATH/libs_locais"
rm -f  "$SGOINFRE_PATH/stremio"

echo "-> Removendo o launcher/symlink no home..."
rm -f ~/stremio

echo "-> Limpando resíduos de instalações antigas no goinfre..."
rm -rf "$HOME/goinfre/stremio-shell" "$HOME/goinfre/qt" "$HOME/goinfre/libs_locais" "$HOME/goinfre/stremio"

echo "-> Removendo configuração e cache do servidor de streaming..."
rm -rf "$HOME/.stremio-server"

echo "-> Removendo o Node 18 instalado via nvm..."
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
    . "$NVM_DIR/nvm.sh"
    nvm uninstall 18 2>/dev/null && echo "   -> Node 18 removido." || echo "   -> Node 18 não estava instalado."
else
    echo "   -> nvm não encontrado."
fi

echo "-> Removendo a ferramenta aqtinstall (pip --user)..."
pip uninstall -y aqtinstall 2>/dev/null || true

echo "-> Limpando o log do aqtinstall..."
rm -f ~/aqtinstall.log "$SGOINFRE_PATH/stremio-shell/aqtinstall.log" 2>/dev/null || true

echo ""
echo "✅ Desinstalação total concluída."
